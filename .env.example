# Copy to .env and fill in values. Do not commit .env with real passwords.

# PostgreSQL database URL.
# Local Docker default:
# DATABASE_URL="postgresql://panel:panel_password@localhost:5432/panel_db"
# Production: put the real VPS database URL here.
DATABASE_URL="postgresql://panel:panel_password@localhost:5432/panel_db"

# Public URL of the panel app. Use the deployed subdomain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP — Hostinger example: smtp.hostinger.com, port 465, SSL
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=
SMTP_FROM=noreply@example.com

# App secret for sessions and auth.
AUTH_SECRET=
